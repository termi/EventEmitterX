{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "allowJs": true,
        "types": ["vitest/globals", "@testing-library/jest-dom"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "../logic/**/*.ts",
        "../utils/**/*.ts",
        "../api/**/*.ts",
        "../type_guards/**/*.ts",
        "../types/**/*.d.ts",
        "../modules/**/*.d.ts",
        "../polyfills/**/*.ts"
    ]
}

