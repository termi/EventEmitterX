{
//  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vite/client"],
    "outDir": "./build/ts-output",
    "lib": [ "DOM", "ESNext", "ES2025", "ES2024", "ES2023", "ES2022", "ES2021", "ES2020", "ES2019", "ES2018", "ES2017", "ES2016", "ES2015" ],
    // https://www.typescriptlang.org/tsconfig/#allowSyntheticDefaultImports
    // Решение ошибки `TS1259: Module '"@types/react/index"' can only be default-imported using the 'esModuleInterop' flag`.
    // Используется совместно с `"esModuleInterop": true`
    // Чтобы можно было писать
    //  `import React from "react";`
    //  вместо
    //  `import * as React from "react";`
    // todo: На данный момент [27.08.2024] не работает почему-то
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "composite": true,
    "skipLibCheck": true,
    "alwaysStrict": true,
    "noResolve": false,
    "preserveConstEnums": true,
    "isolatedModules": false,
    "moduleDetection": "force",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react",
    "newLine": "lf",
    "resolveJsonModule": false,
    "allowImportingTsExtensions": true
  },
  "__include": [
    "./types/global.d.ts",
    "./types/pip.d.ts",
    "./types/document-picture-in-picture.d.ts"
  ],
  "include": [
    "**/*.jsx",
    "**/*.js",
    "**/*.tsx",
    "**/*.ts"
  ]
}
